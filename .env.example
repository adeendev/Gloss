# ============================================
# Gloss - Environment Configuration
# ============================================

# --- Database ---
# SQLite (local dev - works out of the box):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/booking_db"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"

# --- WhatsApp Business API ---
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_ACCESS_TOKEN="your_access_token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your_random_verify_token"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_NAME="Elite Car Detailing"
NEXT_PUBLIC_CURRENCY="USD"
ADVANCE_PAYMENT_PERCENTAGE=20

# --- Cron (for production reminders) ---
# CRON_SECRET="your-cron-secret"
